{
  "manifest_version": 3,
  "name": "CSFloat Bulk Add to Cart",
  "version": "1.0.0",
  "description": "Bulk add the first N items on a CSFloat search page to your cart.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://csfloat.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CSFloat Bulk Add to Cart",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://csfloat.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
